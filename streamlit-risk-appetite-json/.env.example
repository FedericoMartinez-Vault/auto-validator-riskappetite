FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project
FOUNDRY_AGENT_NAME=AF-UW-RiskApetite
AZURE_TENANT_ID=

# Local dev
USE_AZURE_CLI_AUTH=true
USE_MANAGED_IDENTITY=false

# VM — permanent (recommended): managed identity after grant-vm-foundry-role.sh
# USE_AZURE_CLI_AUTH=false
# USE_MANAGED_IDENTITY=true

# VM — optional: SP secrets in Key Vault (after grant-vm-keyvault-role.sh)
# KEY_VAULT_NAME=AZR-DEV-AI-AF-RDOH-KV
# KEY_VAULT_SP_CLIENT_ID_SECRET=foundry-sp-client-id
# KEY_VAULT_SP_CLIENT_SECRET_SECRET=foundry-sp-client-secret

# VM — production: service principal in .env (no expiry until secret rotation)
# USE_AZURE_CLI_AUTH=false
# USE_MANAGED_IDENTITY=false
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# VM — legacy dev only: short-lived user token (~1 hour)
# USE_AZURE_CLI_AUTH=false
# USE_MANAGED_IDENTITY=false
# AZURE_ACCESS_TOKEN=
# AZURE_TOKEN_EXPIRES_ON=
