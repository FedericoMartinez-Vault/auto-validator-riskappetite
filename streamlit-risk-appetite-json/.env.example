FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project
FOUNDRY_AGENT_NAME=AF-UW-RiskApetite

# Local dev: az login, then run sync-env-from-azure.ps1 (without -ForVm)
USE_AZURE_CLI_AUTH=true
USE_MANAGED_IDENTITY=false

# VM deploy (automated): run sync-env-from-azure.ps1 -ForVm or azure-deploy.ps1
# USE_AZURE_CLI_AUTH=false
# USE_MANAGED_IDENTITY=false
# AZURE_TENANT_ID=
# AZURE_ACCESS_TOKEN=          # from: az account get-access-token --resource https://ai.azure.com
# AZURE_TOKEN_EXPIRES_ON=      # unix timestamp from the same command

# Production VM: service principal with Azure AI Developer on Foundry
# USE_AZURE_CLI_AUTH=false
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# VM alternative: managed identity with Azure AI Developer on Foundry
# USE_MANAGED_IDENTITY=true
# USE_AZURE_CLI_AUTH=false
# AZURE_CLIENT_ID=          # optional user-assigned identity client id
